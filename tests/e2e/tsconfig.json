{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"noImplicitAny": true,
		"noUnusedLocals": false,
		"types": [ "node" ],
		"baseUrl": ".",
		"paths": {
			"@helpers/*": [ "./helpers/*" ]
		}
	},
	"include": [ "**/*.ts" ],
	"exclude": [ "iu-test-helpers/**", "fixtures/**", "node_modules" ]
}
