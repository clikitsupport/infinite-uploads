{
	"$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/trunk/schemas/json/wp-env.json",
	"core": "WordPress/WordPress",
	"phpVersion": "8.0",
	"plugins": [
		".",
		"https://downloads.wordpress.org/plugin/beaver-builder-lite-version.latest-stable.zip",
		"./tests/e2e/iu-test-helpers"
	],
	"themes": [],
	"env": {
		"development": {
			"config": {
				"WP_DEBUG": true,
				"WP_DEBUG_LOG": true,
				"WP_DEBUG_DISPLAY": false,
				"SCRIPT_DEBUG": true,
				"WP_ENVIRONMENT_TYPE": "development",
				"INFINITE_UPLOADS_DISABLE_REPLACE_UPLOAD_URL": false
			}
		},
		"tests": {
			"config": {
				"WP_DEBUG": true,
				"WP_DEBUG_LOG": true,
				"WP_DEBUG_DISPLAY": false,
				"WP_ENVIRONMENT_TYPE": "local",
				"INFINITE_UPLOADS_DISABLE_REPLACE_UPLOAD_URL": false
			},
			"mappings": {
				"wp-content/uploads/bb-plugin/cache": "./tests/e2e/fixtures/bb-cache-seed"
			}
		}
	},
	"port": 8889,
	"testsPort": 8890
}
